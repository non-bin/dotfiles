{
  // Workspaces
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "show-special": true,
    "format": "<sub>{icon}</sub>\n{windows}",
    "format-window-separator": "\n",
    "window-rewrite-default": "пЃ™",
    "window-rewrite": {
      "title<.*youtube.*>": "п…Є", // Windows whose titles contain "youtube"
      "class<firefox>": "п‰©", // Windows whose classes are "firefox"
      "class<firefox> title<.*github.*>": "п„“", // Windows whose class is "firefox" and title contains "github". Note that "class" always comes first.
      "foot": "оћ•", // Windows that contain "foot" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
      "code": "у°Ёћ"
    }
  },

  // Hyprland Window
  "hyprland/window": {
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },

  // Rofi Application Launcher
  "custom/appmenu": {
    "format": "Apps",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings",
    "on-click": "rofi -show drun -replace",
    "on-click-right": "~/.config/ml4w/scripts/keybindings.sh",
    "tooltip": false
  },

  // Power Menu
  "custom/exit": {
    "format": "пЂ‘",
    "tooltip-format": "Powermenu",
    "on-click": "wlogout -b 4",
    "tooltip": false
  },

  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "пЂЈ",
      "unlocked": "п‚њ"
    }
  },

  // System tray
  "tray": {
    // "icon-size": 21,
    "spacing": 10
  },

  // Clock
  "clock": {
    // "timezone": "America/New_York",
    "tooltip-format": "<big>{:%a %e %b %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "interval": 1,
    "format": "{:%I:%M %Y-%m-%d}",
    "format-alt": "{:%I:%M:%S}"
  },

  // System
  "custom/system": {
    "format": "о‘і",
    "tooltip": false
  },

  // CPU
  "cpu": {
    "format": "/ C {usage}% ",
    "on-click": "alacritty -e htop"
  },

  // Memory
  "memory": {
    "format": "/ M {}% ",
    "on-click": "alacritty -e htop"
  },

  // Harddisc space used
  "disk": {
    "interval": 30,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "alacritty -e htop"
  },

  "hyprland/language": {
    "format": "/ K {short}"
  },

  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": ["custom/system", "disk", "cpu", "memory", "hyprland/language"]
  },

  // Network
  "network": {
    "format": "{ifname}",
    "format-wifi": "п‡«   {signalStrength}%",
    "format-ethernet": "пћ–  {ipaddr}",
    "format-disconnected": "Not connected", //An empty format will hide the module.
    "tooltip-format": "пћ– {ifname} via {gwaddri}",
    "tooltip-format-wifi": "п‡«   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "пѓЃ  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "alacritty -e nmtui"
  },

  // Battery
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}   {capacity}%",
    "format-charging": "п—§  {capacity}%",
    "format-plugged": "п‡¦  {capacity}%",
    "format-alt": "{icon}  {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["п‰„ ", "п‰ѓ ", "п‰‚ ", "п‰Ѓ ", "п‰Ђ "]
  },

  // Pulseaudio
  "pulseaudio": {
    "scroll-step": 5, // %, can be a float
    "reverse-scrolling": true,
    "max-volume": 150,
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",
    "format-bluetooth-muted": "пљ© {icon}пЉ” {format_source}",
    "format-muted": "пљ© {format_source}",
    "format-source": "{volume}% п„°",
    "format-source-muted": "п„±",
    "format-icons": {
      "headphone": "пЂҐ",
      "hands-free": "п–ђ",
      "headset": "п–ђ",
      "phone": "п‚•",
      "portable": "п‚•",
      "car": "п†№",
      "default": ["пЂ¦", "пЂЁ ", "пЂЁ "]
    },
    "interval": 10,
    "on-click": "pavucontrol"
  },

  // Bluetooth
  "bluetooth": {
    "format": "пЉ” {num_connections}",
    "format-connected-battery": "пЉ” {num_connections} ({device_battery_percentage})",
    "format-disabled": "пЉ” Disabled",
    "format-off": "пЉ” Off",
    "interval": 10,
    "format-no-controller": "пЉ” Error",
    "on-click": "blueman-manager",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "tooltip-format": "Status: {status}\n\nDevices:\n{device_enumerate}\n\nClick: blueman-manager"
  },

  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  // Idle Inhibator
  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "пЏЃ",
      "deactivated": "пЂЈ"
    },
    "on-click-right": "hyprlock"
  }
}
